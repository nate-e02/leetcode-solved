class Solution:
    def canJump(self, nums: List[int]) -> bool:
        length = len(nums) - 1
        if nums[0] == 0 and length > 0:
            return False
        if nums[0] == length:
            return True    
        for i in range(length):
            if nums[i] == 0:
                x = 0
                while (nums[i] <= x):
                    i -= 1
                    x += 1 
                    if ( i == -1 ):
                        return False
        return True  
