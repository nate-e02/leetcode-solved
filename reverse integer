import math
class Solution:
    def reverse(self, x: int) -> int:
        res = 0
        negative = x<0
        new = str(abs(x))
        p = 0
        for nums in new:        
            res += int(nums) * (10 ** p)
            p+=1          
        if res > 2**31 - 1:
            return 0
           
        else:
            if negative:
                res = -res      
            return res 
