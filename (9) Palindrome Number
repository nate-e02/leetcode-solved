class Solution:
    def isPalindrome(self, x: int) -> bool:
        word = str(x)
        new = ""
        if (x == 0):
                new = new + "0"
        while (x > 0):
            temp = x % 10
            new = new + str(temp)
            x = x // 10
        if (word == new):
            return True
        else:
            return False


 
