class Solution:
    def sortColors(self, nums: List[int]) -> None:
        """
        Do not return anything, modify nums in-place instead.
        """
        new = []
        x = 0
        for x in range(3):
            count = 0
            for num in nums:
                if (num == x):
                    count += 1
            if x not in new:
                for i in range(count):
                    new.append(x)
        nums[:] = new  
